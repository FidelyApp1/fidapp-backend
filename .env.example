DATABASE_URL=
DIRECT_URL=
JWT_SECRET=
JWT_EXPIRES_IN=7d
PORT=3000
NODE_ENV=development

# URLs & CORS — local
CLIENT_APP_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Production (exemple fidapp.ma)
# CLIENT_APP_URL=https://fidapp.ma
# CORS_ORIGINS=https://fidapp.ma,https://pro.fidapp.ma,https://admin.fidapp.ma
# Sécurité
ALLOW_PUBLIC_REGISTER=false
ADMIN_EMAIL=admin@fidapp.ma
ADMIN_PASSWORD=

# SMS OTP (Twilio) — requis en production
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
